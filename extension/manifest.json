{
  "manifest_version": 3,
  "name": "LinkedIn Puzzle Solver Assistant",
  "version": "0.1.0",
  "description": "Capture puzzle boards, solve through a local API, and overlay/apply solutions.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "webNavigation"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://www.linkedin.com/*",
    "https://*.linkedin.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Puzzle Solver",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
